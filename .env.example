APP_NAME=AssistEduc API
APP_VERSION=1.0.0
DEBUG=true
DATABASE_PATH=data/assisteduc.db
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=104857600
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
AUDIO_PREPROCESS_ENABLED=true
AUDIO_PREPROCESS_SAMPLE_RATE=16000
AUDIO_NOISE_GATE_RATIO=0.35
AUDIO_NORMALIZATION_TARGET=0.9
AUDIO_NOISE_REDUCTION_STRENGTH=1.25
AUDIO_HIGH_PASS_ALPHA=0.97
AUDIO_LOW_PASS_ALPHA=0.12
WHISPER_BEAM_SIZE=5
WHISPER_BEST_OF=5
WHISPER_ENABLE_VAD=true
WHISPER_CONDITION_ON_PREVIOUS_TEXT=false
WHISPER_NO_SPEECH_THRESHOLD=0.6
WHISPER_LOG_PROB_THRESHOLD=-1.0
WHISPER_COMPRESSION_RATIO_THRESHOLD=2.4
WHISPER_MIN_LANGUAGE_CONFIDENCE=0.8
TRANSCRIPTION_MAX_SYMBOL_RATIO=0.35
WHISPER_DEFAULT_PROMPT=
SUMMARY_LANGUAGE=french
